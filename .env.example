# database (opzionale - non usato, salvataggio in memoria)
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# telegram
BOT_TOKEN=your_bot_token_here
BOT_API_URL=https://api.telegram.org
CONCURRENT_UPDATES=50

# media
DOWNLOADS_DIR=downloads
MAX_DURATION=3600
MAX_FILE_SIZE=1000

# proxy (opzionale)
PROXY=

# impostazioni di default
DEFAULT_ENABLE_CAPTIONS=true
DEFAULT_ENABLE_SILENT=false
DEFAULT_ENABLE_NSFW=false
DEFAULT_MEDIA_ALBUM_LIMIT=10
DEFAULT_LANGUAGE=en
DEFAULT_DELETE_LINKS=false

# altre impostazioni
REPO_URL=https://github.com/govdbot/govd
LOG_LEVEL=info
CACHING=true
ADMINS=
WHITELIST=
CAPTIONS_HEADER=<a href='{{url}}'>source</a> - @{{username}}
CAPTIONS_DESCRIPTION=<blockquote>{{text}}</blockquote>
AUTOMATIC_LANGUAGE_DETECTION=true
